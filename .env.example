APP_NAME=mini-failover-demo

DB_DRIVER=postgresql+asyncpg
DB_ECHO=false

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

DB_PRIMARY_HOST=127.0.0.1
DB_PRIMARY_PORT=15432
DB_SECONDARY_HOST=127.0.0.1
DB_SECONDARY_PORT=15433

TCP_CONNECT_TIMEOUT_IN_SECONDS=5
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT_IN_SECONDS=10
DB_POOL_RECYCLE_IN_SECONDS=1800
POSTGRES_STATEMENT_TIMEOUT_STR=5000
DB_HOST_HEALTH_CHECK_INTERVAL_IN_SECONDS=2
DB_HOST_COOLDOWN_INTERVAL_IN_SECONDS=2
DB_HOST_WRITABLE_TIMEOUT_IN_SECONDS=10
